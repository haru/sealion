# Postgres service credentials — used by both the db service and app's DATABASE_URL
# (DATABASE_URL is auto-generated in docker-compose.yml from these values)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=sealion_dev

# Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Credential encryption key — exactly 32 bytes hex = 64 hex chars
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=""

# Optional: Host-side port mapping (container always listens on 3000)
# HOST_PORT=3000

# Optional: DB healthcheck variables (used by docker/entrypoint.sh)
# DB_PORT=5432
# DB_USER=postgres
# DB_MAX_RETRIES=30
# DB_RETRY_INTERVAL=2
