# Database — use 'db' as the hostname (Docker Compose service name, not localhost)
DATABASE_URL="postgresql://postgres:password@db:5432/sealion_dev"

# Auth.js (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Credential encryption key — exactly 32 bytes hex = 64 hex chars
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=""

# App URL
NEXTAUTH_URL="http://localhost:3000"

# Optional: DB healthcheck variables (used by docker/entrypoint.sh)
# DB_PORT=5432
# DB_USER=postgres
# DB_MAX_RETRIES=30
# DB_RETRY_INTERVAL=2
