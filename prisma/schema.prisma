generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ProviderType {
  GITHUB
  JIRA
  REDMINE
  GITLAB
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  username     String?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  issueProviders IssueProvider[]
  accounts       Account[]
  sessions       Session[]
  boardSettings  BoardSettings?
}

model BoardSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  showCreatedAt Boolean  @default(true)
  showUpdatedAt Boolean  @default(false)
  sortOrder     Json     @default("[\"dueDate_asc\",\"providerUpdatedAt_desc\"]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IssueProvider {
  id                   String       @id @default(cuid())
  userId               String
  type                 ProviderType
  displayName          String
  baseUrl              String?
  encryptedCredentials String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
}

model Project {
  id                String    @id @default(cuid())
  issueProviderId   String
  externalId        String
  displayName       String
  includeUnassigned Boolean   @default(false)
  lastSyncedAt      DateTime?
  syncError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  issueProvider IssueProvider @relation(fields: [issueProviderId], references: [id], onDelete: Cascade)
  issues        Issue[]

  @@unique([issueProviderId, externalId])
  @@index([issueProviderId])
}

model Issue {
  id           String    @id @default(cuid())
  projectId    String
  externalId   String
  title        String
  dueDate      DateTime?
  externalUrl  String
  isUnassigned Boolean   @default(false)
  lastSyncedAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Today Tasks feature fields
  todayFlag    Boolean   @default(false)
  todayOrder   Int?
  todayAddedAt DateTime?

  // Provider-side timestamps (007-task-list-sort)
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?

  // Task pin feature (018-task-pin)
  pinned Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
  @@index([projectId])
  @@index([dueDate])
  @@index([todayFlag, todayOrder])
  @@index([dueDate, providerUpdatedAt, providerCreatedAt])
  @@index([pinned])
}

// ─── Auth Settings ───────────────────────────────────────────────────────────

model AuthSettings {
  id                    String   @id @default("singleton")
  allowUserSignup       Boolean  @default(true)
  sessionTimeoutMinutes Int?
  updatedAt             DateTime @updatedAt
}

// ─── Auth.js required tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
