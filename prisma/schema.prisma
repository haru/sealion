generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ProviderType {
  GITHUB
  JIRA
  REDMINE
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  CLOSED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  issueProviders IssueProvider[]
  accounts       Account[]
  sessions       Session[]
}

model IssueProvider {
  id                   String       @id @default(cuid())
  userId               String
  type                 ProviderType
  displayName          String
  baseUrl              String?
  encryptedCredentials String
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
}

model Project {
  id              String    @id @default(cuid())
  issueProviderId String
  externalId      String
  displayName       String
  includeUnassigned Boolean   @default(false)
  lastSyncedAt      DateTime?
  syncError         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  issueProvider IssueProvider @relation(fields: [issueProviderId], references: [id], onDelete: Cascade)
  issues        Issue[]

  @@unique([issueProviderId, externalId])
  @@index([issueProviderId])
}

model Issue {
  id           String        @id @default(cuid())
  projectId    String
  externalId   String
  title        String
  status       IssueStatus   @default(OPEN)
  priority     IssuePriority @default(MEDIUM)
  dueDate      DateTime?
  externalUrl   String
  isUnassigned  Boolean       @default(false)
  lastSyncedAt  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Today Tasks feature fields
  todayFlag    Boolean   @default(false)
  todayOrder   Int?
  todayAddedAt DateTime?

  // Provider-side timestamps (007-task-list-sort)
  providerCreatedAt DateTime?
  providerUpdatedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
  @@index([projectId])
  @@index([status, dueDate])
  @@index([todayFlag, todayOrder])
  @@index([dueDate, providerUpdatedAt, providerCreatedAt])
}

// ─── Auth.js required tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
